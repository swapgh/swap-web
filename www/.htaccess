RewriteEngine On
RewriteBase /

# 1. Set the default index file
DirectoryIndex index.php index.html

# 1.5 NEW: Serve assets from parent ../assets/ if not found locally (for outside www/)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_URI} ^/assets/
RewriteRule ^assets/(.*)$ ../assets/$1 [L]

# 2. Serve existing files directly (CSS, JS, Images)
# If the request matches a physical file, stop here and serve it.
RewriteCond %{REQUEST_FILENAME} -f
RewriteRule ^ - [L]

# 3. Serve existing directories directly
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# 4. Send everything else to index.php (Front Controller)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^ index.php [L]

# 5. Custom 404 (Optional)
ErrorDocument 404 /index.php
